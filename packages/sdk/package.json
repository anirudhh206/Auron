{
  "name": "@auron/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Auron settlement infrastructure",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build":      "tsup src/index.ts --format cjs,esm --dts",
    "dev":        "tsup src/index.ts --format cjs,esm --dts --watch",
    "type-check": "tsc --noEmit",
    "lint":       "eslint src/"
  },
  "keywords": ["auron", "solana", "usdc", "upi", "settlement", "payments", "india"],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
