# ─────────────────────────────────────────────────────────────────────────────
# Auron — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# .env.local is in .gitignore — it will NEVER be committed to git.
# Set production values in your Vercel dashboard under Project → Settings → Env Vars.
# ─────────────────────────────────────────────────────────────────────────────

# ─── AI ──────────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Solana Network ───────────────────────────────────────────────────────────
# "devnet" for development, "mainnet-beta" for production
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# ─── RPC Endpoint ────────────────────────────────────────────────────────────
# Leave empty to use public RPC (fine for devnet / development)
# For mainnet-beta: use Helius (https://helius.dev) or QuickNode — public RPC is rate-limited
# Example: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
NEXT_PUBLIC_HELIUS_RPC_URL=

# ─── Treasury Wallet (PUBLIC — safe to expose) ────────────────────────────────
# The Auron treasury wallet that receives USDC from users
# Create a new wallet in Phantom → copy the public address here
NEXT_PUBLIC_FEE_WALLET=your_treasury_wallet_public_address_here

# ─── USDC Mint Address (PUBLIC — safe to expose) ─────────────────────────────
# Mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# Devnet:  Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr  (spl-token-faucet)
NEXT_PUBLIC_USDC_MINT=Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr

# ─── Savings Vault Program ID ────────────────────────────────────────────────
# Devnet default is set in code — override here when deploying to mainnet
NEXT_PUBLIC_SAVINGS_VAULT_PROGRAM_ID=B5DwqnCoDrY8ezfGaZfpAnvZ4FwCtPNHk6vT5nRgFENg

# ─── FX Rate Config ───────────────────────────────────────────────────────────
# Fallback rate used only when CoinGecko is unreachable — never used for tx amounts
# Update this periodically to a reasonable market rate
NEXT_PUBLIC_FALLBACK_FX_RATE=84.00
FALLBACK_FX_RATE_INR=84.00

# ─── Spread Config ───────────────────────────────────────────────────────────
# Auron's FX revenue spread (0.0085 = 0.85%)
# Client-side display uses NEXT_PUBLIC_ prefix; server-side quote uses the unprefixed one
NEXT_PUBLIC_AURON_SPREAD_PERCENT=0.85
AURON_SPREAD_PERCENT=0.0085

# ─── OnMeta Off-Ramp ─────────────────────────────────────────────────────────
# SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_
# "demo"        → internal mock (no real API calls)
# "sk_test_xxx" → OnMeta sandbox (real API, fake INR) — email dev@onmeta.in
# "sk_live_xxx" → OnMeta production (real INR to merchant) — requires KYC
ONMETA_API_KEY=demo

# ─── OnMeta Webhook Secret ───────────────────────────────────────────────────
# SERVER-SIDE ONLY — used to verify UTR confirmation webhooks from OnMeta
# Set this once OnMeta provides your webhook secret in their dashboard
ONMETA_WEBHOOK_SECRET=

# ─── Treasury Keypair ────────────────────────────────────────────────────────
# SERVER-SIDE ONLY — NEVER prefix with NEXT_PUBLIC_ — NEVER commit this value
# Base58-encoded private key of the treasury wallet (used to sign refund txs)
# How to get: Phantom → Settings → Security → Export Private Key
# WARNING: Anyone with this key controls the treasury. Treat like a password.
TREASURY_KEYPAIR_BASE58=
